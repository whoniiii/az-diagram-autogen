{
  "architecture_description": "하이브리드 네트워크 아키텍처. Hub VNet(10.0.0.0/16)에 VPN Gateway(S2S, 온프레미스 192.168.0.0/16), Azure Firewall(Premium), Bastion 배치. Spoke VNet(10.1.0.0/16)에 App Service, Azure SQL Database, Key Vault 배치. Hub-Spoke 피어링으로 트래픽 제어.",
  "services": [
    {
      "id": "vpn-gateway",
      "name": "VPN Gateway",
      "type": "vpn_gateway",
      "sku": "VpnGw1",
      "private": false,
      "details": [
        "Site-to-Site VPN",
        "온프레미스 연결: 192.168.0.0/16",
        "Hub VNet: 10.0.0.0/16"
      ],
      "resourceGroup": "rg-hub"
    },
    {
      "id": "firewall",
      "name": "Azure Firewall",
      "type": "firewall",
      "sku": "Premium",
      "private": false,
      "details": [
        "SKU: Premium",
        "Hub 중앙 방화벽",
        "네트워크/애플리케이션 규칙"
      ],
      "resourceGroup": "rg-hub"
    },
    {
      "id": "bastion",
      "name": "Azure Bastion",
      "type": "bastion",
      "sku": "Standard",
      "private": false,
      "details": [
        "보안 원격 접속",
        "Hub VNet 내 배포",
        "SKU: Standard"
      ],
      "resourceGroup": "rg-hub"
    },
    {
      "id": "app-service",
      "name": "Azure App Service",
      "type": "app_service",
      "sku": "P1v3",
      "private": false,
      "details": [
        "웹 애플리케이션 호스팅",
        "Spoke VNet: 10.1.0.0/16",
        "VNet Integration"
      ],
      "resourceGroup": "rg-workload"
    },
    {
      "id": "sql-database",
      "name": "Azure SQL Database",
      "type": "sql_database",
      "sku": "Standard S1",
      "private": false,
      "details": [
        "관계형 데이터베이스",
        "SKU: Standard S1",
        "Spoke VNet 내 서비스 엔드포인트"
      ],
      "resourceGroup": "rg-workload"
    },
    {
      "id": "key-vault",
      "name": "Azure Key Vault",
      "type": "keyvault",
      "sku": "Standard",
      "private": false,
      "details": [
        "시크릿 및 키 관리",
        "RBAC authorization",
        "Spoke VNet 내 배치"
      ],
      "resourceGroup": "rg-workload"
    }
  ],
  "connections": [
    {
      "from": "vpn-gateway",
      "to": "firewall",
      "label": "온프레미스 → Hub 트래픽",
      "type": "network"
    },
    {
      "from": "firewall",
      "to": "app-service",
      "label": "Hub → Spoke 라우팅",
      "type": "network"
    },
    {
      "from": "bastion",
      "to": "app-service",
      "label": "보안 원격 관리 접속",
      "type": "network"
    },
    {
      "from": "app-service",
      "to": "sql-database",
      "label": "데이터 읽기/쓰기",
      "type": "data"
    },
    {
      "from": "app-service",
      "to": "key-vault",
      "label": "Secrets",
      "type": "security"
    },
    {
      "from": "sql-database",
      "to": "key-vault",
      "label": "연결 문자열 관리",
      "type": "security"
    }
  ],
  "vnet_info": "Hub VNet: 10.0.0.0/16 (GatewaySubnet, AzureFirewallSubnet, AzureBastionSubnet) | Spoke VNet: 10.1.0.0/16 (app-subnet, data-subnet) | VPN S2S: 온프레미스 192.168.0.0/16",
  "hierarchy": [
    {
      "subscription": "hybrid-network-sub",
      "resourceGroups": ["rg-hub", "rg-workload"]
    }
  ]
}
