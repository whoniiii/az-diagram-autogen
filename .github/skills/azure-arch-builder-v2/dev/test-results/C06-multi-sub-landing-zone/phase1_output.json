{
  "architecture_description": "Azure Landing Zone 구조의 엔터프라이즈 아키텍처. Connectivity 구독에 Hub VNet(Firewall, Bastion, VPN Gateway)을 배치하고, Workload 구독에 Spoke VNet(AI Foundry, AI Search, Storage, Key Vault)을 배치하여 Hub-Spoke 네트워크 토폴로지를 구성한다.",
  "services": [
    {
      "id": "firewall",
      "name": "Azure Firewall",
      "type": "firewall",
      "sku": "Premium",
      "private": false,
      "details": [
        "Hub VNet의 AzureFirewallSubnet에 배치",
        "IDPS 및 TLS 검사 지원 (Premium SKU)",
        "Spoke→Internet 트래픽 중앙 제어",
        "CIDR: 10.0.1.0/26"
      ],
      "subscription": "connectivity-sub",
      "resourceGroup": "rg-connectivity-hub"
    },
    {
      "id": "bastion",
      "name": "Azure Bastion",
      "type": "bastion",
      "sku": "Standard",
      "private": false,
      "details": [
        "Hub VNet의 AzureBastionSubnet에 배치",
        "CIDR: 10.0.2.0/26",
        "Spoke VNet VM에 안전한 RDP/SSH 접근"
      ],
      "subscription": "connectivity-sub",
      "resourceGroup": "rg-connectivity-hub"
    },
    {
      "id": "vpn-gateway",
      "name": "VPN Gateway",
      "type": "vpn_gateway",
      "sku": "VpnGw1",
      "private": false,
      "details": [
        "Hub VNet의 GatewaySubnet에 배치",
        "CIDR: 10.0.3.0/27",
        "온프레미스 네트워크와 S2S VPN 연결",
        "IKEv2 지원"
      ],
      "subscription": "connectivity-sub",
      "resourceGroup": "rg-connectivity-hub"
    },
    {
      "id": "ai-foundry",
