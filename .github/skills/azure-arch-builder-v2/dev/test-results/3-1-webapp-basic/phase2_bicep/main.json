      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-sql'), '2025-04-01').outputs.sqlDatabaseName.value]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-keyvault'), '2025-04-01').outputs.keyVaultUri.value]"
    }
  }
